# eBay: App ID = CLIENT_ID, Cert ID = CLIENT_SECRET (developer.ebay.com)
# Production: use https://api.ebay.com — Sandbox: https://api.sandbox.ebay.com
EBAY_CLIENT_ID=your_ebay_app_id
EBAY_CLIENT_SECRET=your_ebay_cert_id

# SerpApi — covers both Amazon and Google Shopping (serpapi.com)
SERPAPI_KEY=your_serpapi_key

# Apify — Facebook Marketplace scraper (apify.com)
APIFY_API_KEY=your_apify_token

# Etsy — App API Key from developer.etsy.com (no OAuth needed for public search)
ETSY_API_KEY=your_etsy_api_key

# KicksDB — StockX sold price data (kicks.dev)
KICKSDB_API_KEY=your_kicksdb_key

# Google Gemini — query generation + price synthesis (aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key
# Optional: override model (default gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# PriceCharting — requires premium subscription (pricecharting.com/api)
PRICECHARTING_API_KEY=your_pricecharting_token

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_SSL=false
